# -----------------------------------------------------------
# 1. Python 编译缓存 (必须忽略)
# -----------------------------------------------------------
# 忽略所有 .pyc 和 .pyo 文件
*.py[cod]
*$py.class

# 忽略 __pycache__ 文件夹 (Python 3 自动生成的缓存目录)
__pycache__/

# 忽略分布/构建文件夹
dist/
build/
*.egg-info/

# -----------------------------------------------------------
# 2. 虚拟环境 (通常不需要提交)
# -----------------------------------------------------------
venv/
env/
.venv/
ENV/

# -----------------------------------------------------------
# 3. IDE 和编辑器配置 (可选，保持仓库干净)
# -----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------
# 4. 系统临时文件
# -----------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------
# 5. 日志和大型数据 (根据需求调整)
# -----------------------------------------------------------
*.log
logs/
tmp/
temp/

# ⚠️ 注意：
# -----------------------------------------------------------
# 6. 数据集.mat文件 (大型文件超过100MB)
# -----------------------------------------------------------
*.mat
data/